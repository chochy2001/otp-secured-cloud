# ------------------------------------------------------------------
# Variables de entorno del proyecto otp-secured-cloud
# ------------------------------------------------------------------
# AVISO: este archivo con contraseñas se versiona en el repositorio a
# propósito porque se trata de un proyecto académico y el equipo
# necesita poder levantar el entorno sin intercambiar secretos por
# otro canal. En un entorno real ESTO SERÍA UNA MALA PRÁCTICA.
#
# Patrón memorable: sia-<rol>-2026
# ------------------------------------------------------------------

# OpenLDAP: parámetros del directorio
LDAP_ORGANISATION="SIA UNAM FI"
LDAP_DOMAIN=sia.unam.mx
LDAP_BASE_DN=dc=sia,dc=unam,dc=mx

# OpenLDAP: contraseñas
LDAP_ADMIN_PASSWORD=sia-admin-2026
LDAP_CONFIG_PASSWORD=sia-config-2026
LDAP_SERVICE_PASSWORD=sia-svc-2026

# Contraseña compartida por los 6 usuarios de prueba
# (coincide con userPassword en los LDIFs 02 y 03)
LDAP_USER_PASSWORD=sia-user-2026

# PrivacyIDEA: credenciales del admin que se crea al primer arranque
PI_ADMIN_USERNAME=admin
PI_ADMIN_PASSWORD=sia-pi-admin-2026

# PrivacyIDEA: secretos criptográficos usados en la config Flask
PI_PEPPER=sia-pi-pepper-2026
PI_SECRET_KEY=sia-pi-secret-2026

# PrivacyIDEA: nombres del resolver y realm que apuntarán al LDAP
PI_RESOLVER_NAME=sia-ldap
PI_REALM_NAME=sia

# PrivacyIDEA: conexión interna del resolver hacia OpenLDAP
PI_LDAP_URI=ldaps://openldap:636
PI_LDAP_TLS_CA_FILE=/etc/privacyidea/ssl/ca.crt

# URL local para probar privacyIDEA desde el host
PI_URL=https://localhost:8443

# Ruta a la CA del proyecto que firma los certs de openldap y privacyidea.
# Los scripts la pasan a curl como --cacert para validar HTTPS local.
PI_CA_BUNDLE=certs/ca.crt
