# ------------------------------------------------------------------
# Plantilla. En este repo el archivo .env real también se versiona
# (ver aviso en .gitignore y en README.md). Este archivo queda solo
# como referencia de qué variables existen.
# ------------------------------------------------------------------

# OpenLDAP: parámetros del directorio
LDAP_ORGANISATION="SIA UNAM FI"
LDAP_DOMAIN=sia.unam.mx
LDAP_BASE_DN=dc=sia,dc=unam,dc=mx

# OpenLDAP: contraseñas (patrón sia-<rol>-2026)
LDAP_ADMIN_PASSWORD=cambia-esto
LDAP_CONFIG_PASSWORD=cambia-esto
LDAP_SERVICE_PASSWORD=cambia-esto

# Contraseña compartida por los 6 usuarios de prueba
LDAP_USER_PASSWORD=cambia-esto

# PrivacyIDEA: credenciales del admin inicial
PI_ADMIN_USERNAME=admin
PI_ADMIN_PASSWORD=cambia-esto

# PrivacyIDEA: secretos criptográficos
PI_PEPPER=cambia-esto
PI_SECRET_KEY=cambia-esto

# PrivacyIDEA: nombres del resolver y realm
PI_RESOLVER_NAME=sia-ldap
PI_REALM_NAME=sia

# PrivacyIDEA: conexión interna del resolver hacia OpenLDAP
PI_LDAP_URI=ldaps://openldap:636
PI_LDAP_TLS_CA_FILE=/etc/privacyidea/ssl/ca.crt

PI_URL=https://localhost:8443
PI_CA_BUNDLE=certs/ca.crt

# OwnCloud
OC_ADMIN_USERNAME=admin
OC_ADMIN_PASSWORD=cambia-esto
OC_DB_ROOT_PASSWORD=cambia-esto
OC_DB_PASSWORD=cambia-esto
OC_URL=https://localhost:9443
OC_CA_BUNDLE=certs/ca.crt
